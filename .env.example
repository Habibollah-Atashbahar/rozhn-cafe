# اطلاعات اتصال به دیتابیس Redis (Upstash) — سفارش‌ها، محصولات و نظرات اینجا ذخیره می‌شوند.
# از داشبورد Upstash یا تب Storage در Vercel قابل دریافت است.
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxx

# فاصله زمانی پولینگ پنل ادمین برای چک کردن سفارش/نظر جدید (میلی‌ثانیه). پیشنهاد: 10000 (۱۰ ثانیه) تا 300000 (۵ دقیقه)
NEXT_PUBLIC_ADMIN_POLL_INTERVAL_MS=15000

# رمز ورود پنل ادمین (سمت سرور Next.js چک می‌شود، هرگز به کلاینت فرستاده نمی‌شود)
ADMIN_PASSWORD=admin_password

# اگر سایت پشت HTTPS واقعی دیپلوی شد این را true کنید تا کوکی ادمین Secure باشد.
# روی شبکه داخلی کافه (بدون HTTPS) حتما false/خالی بماند وگرنه لاگین ادمین کار نمی‌کند.
USE_HTTPS=false
